CODEX_BRIDGE_TOKEN=change-me-local-token
CODEX_BRIDGE_CWD=/workspace
CODEX_BRIDGE_TIMEOUT_MS=600000

# Pick one auth path for Codex inside Docker.
# Option A: Platform/API-key path for codex exec.
CODEX_API_KEY=sk-proj-your-key-here

# Option B: Codex/ChatGPT access token for trusted automation, if your workspace supports it.
# CODEX_ACCESS_TOKEN=your-codex-access-token
